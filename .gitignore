# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Vendored / third-party (large, cloned separately; see requirements.txt) ---
third_party/

