# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Vendored / third-party (large, cloned separately; see requirements.txt) ---
third_party/

# --- Test / tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- Experiment outputs we do NOT version ---
# (checkpoints, wandb runs, raw rollouts). The small reproducible artifacts under
# papers/figures/ — the *.json result dumps and the figure PNG/PDF — ARE tracked.
wandb/
outputs/
multirun/
checkpoints/
*.ckpt
*.pt
*.pth

# --- arXiv build bundle (generated by papers/arxiv/build.py; regenerate, don't version) ---
# The generator (build.py) IS tracked; everything it emits is deterministic and stays out of git
# (regenerate with `python3 arxiv/build.py` from papers/ — see papers/arxiv_submission.md).
papers/arxiv/_combined.md
papers/arxiv/main.tex
papers/arxiv/main.pdf
papers/arxiv/preamble_extra.tex
papers/arxiv/00README.json
papers/arxiv/arxiv_upload.tar.gz
papers/arxiv/figures/
papers/arxiv/*.log
papers/arxiv/main.xdv
papers/arxiv/*.otf
# v2 deliverables are likewise regenerable build outputs (build.py with TARBALL
# redirected to the _v2 name) — frozen on disk for manual upload, not versioned, same as v1.
papers/arxiv/main_v2.tex
papers/arxiv/main_v2.pdf
papers/arxiv/arxiv_upload_v2.tar.gz
# smoke-test result dumps under papers/figures/ are throwaway (real runs drop the non-smoke name)
papers/figures/*_smoke.json
papers/figures/*_smoke.png

# --- OS / editor cruft ---
.DS_Store
*.swp
.idea/
.vscode/
